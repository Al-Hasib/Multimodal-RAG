OPENAI_API_KEY=sk-your-openai-key
GROQ_API_KEY=gsk-your-groq-key

QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0
POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/multimodal_rag

LANGFUSE_PUBLIC_KEY=pk-your-langfuse-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-key
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# Optional overrides
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini
# GROQ_CHAT_MODEL=llama-3.1-8b-instant
# QDRANT_COLLECTION_NAME=multi_modal_rag
# QDRANT_HYBRID=true
# RERANK_ENABLED=true
# RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# QUERY_TRANSFORMER_ENABLED=true
# QUERY_TRANSFORMER_METHOD=hyde
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# REDIS_CACHE_ENABLED=true
# PROMPT_USE_LANGFUSE=false
# PROMPT_DEFAULT_VERSION=1
# LOG_LEVEL=INFO
# LOG_FORMAT=json

# Audio Transcription
# AUDIO_TRANSCRIPTION_PROVIDER=openai
# AUDIO_TRANSCRIPTION_MODEL=whisper-1
# AUDIO_TRANSCRIPTION_LANGUAGE=
# AUDIO_CHUNK_SECONDS=300
# AUDIO_MAX_FILE_SIZE_MB=200

# API Security
# API_KEYS=sk-prod-abc123,sk-prod-def456
# RATE_LIMIT=10/minute
# CORS_ORIGINS=*

# Security & rate limiting
# API_KEYS=sk-prod-key1,sk-prod-key2
# RATE_LIMIT=10/minute
# CORS_ORIGINS=*

# Task queue
# ARQ_REDIS_URL=redis://localhost:6379/1

# Guardrails
# GUARDRAIL_ENABLED=true
# GUARDRAIL_INPUT_CHECK=true
# GUARDRAIL_OUTPUT_CHECK=true
# GUARDRAIL_BLOCK_ON_INPUT_VIOLATION=true
# GUARDRAIL_BLOCK_ON_OUTPUT_VIOLATION=false
# GUARDRAIL_LOG_TO_LANGFUSE=true
